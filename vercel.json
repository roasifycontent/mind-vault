{
  "version": 2,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/auth/checkout-success", "destination": "/api/auth?action=checkout-success" },
    { "source": "/api/auth/verify", "destination": "/api/auth?action=verify" },
    { "source": "/api/auth/magic-link", "destination": "/api/auth?action=magic-link" },
    { "source": "/api/auth/login", "destination": "/api/auth?action=login" },
    { "source": "/api/auth/register", "destination": "/api/auth?action=register" },
    { "source": "/api/auth/google", "destination": "/api/auth?action=google" },
    { "source": "/api/auth/me", "destination": "/api/auth?action=me" },
    { "source": "/api/auth/check", "destination": "/api/auth?action=check" },
    { "source": "/api/auth/logout", "destination": "/api/auth?action=logout" },
    { "source": "/api/auth/forgot-password", "destination": "/api/auth?action=forgot-password" },
    { "source": "/api/auth/reset-password", "destination": "/api/auth?action=reset-password" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/lp", "destination": "/lp.html" },
    { "source": "/quiz", "destination": "/quiz.html" },
    { "source": "/quiz2", "destination": "/quiz2.html" },
    { "source": "/quiz3", "destination": "/quiz3.html" },
    { "source": "/ba-test", "destination": "/quiz.html" },
    { "source": "/mh-check", "destination": "/quiz2.html" },
    { "source": "/ss-quiz", "destination": "/quiz3.html" },
    { "source": "/ms-start", "destination": "/lp.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/testimonials", "destination": "/testimonials.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/reset", "destination": "/reset.html" },
    { "source": "/memory-test", "destination": "/memory-test.html" },
    { "source": "/tip-of-tongue", "destination": "/tip-of-tongue.html" },
    { "source": "/name-recall", "destination": "/name-recall.html" },
    { "source": "/brain-workout", "destination": "/brain-workout.html" },
    { "source": "/family-noticed", "destination": "/family-noticed.html" },
    { "source": "/quiz-prices2", "destination": "/quiz-prices2.html" },
    { "source": "/quiz2-prices2", "destination": "/quiz2-prices2.html" },
    { "source": "/quiz3-prices2", "destination": "/quiz3-prices2.html" },
    { "source": "/lp-prices2", "destination": "/lp-prices2.html" },
    { "source": "/tip-of-tongue-prices2", "destination": "/tip-of-tongue-prices2.html" },
    { "source": "/name-recall-prices2", "destination": "/name-recall-prices2.html" },
    { "source": "/brain-workout-prices2", "destination": "/brain-workout-prices2.html" },
    { "source": "/family-noticed-prices2", "destination": "/family-noticed-prices2.html" },
    { "source": "/angle1-prices2", "destination": "/angle1-prices2.html" },
    { "source": "/angle2-prices2", "destination": "/angle2-prices2.html" },
    { "source": "/angle3-prices2", "destination": "/angle3-prices2.html" },
    { "source": "/angle4-prices2", "destination": "/angle4-prices2.html" },
    { "source": "/angle5-prices2", "destination": "/angle5-prices2.html" },
    { "source": "/start", "destination": "/start.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/assessment", "destination": "/assessment.html" },
    { "source": "/offer-20", "destination": "/offer-20.html" },
    { "source": "/offer-30", "destination": "/offer-30.html" },
    { "source": "/offer-40", "destination": "/offer-40.html" },
    { "source": "/offer-50", "destination": "/offer-50.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
