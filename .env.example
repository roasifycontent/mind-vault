# ─── Neon PostgreSQL ───────────────────────────────────────────
# Get this from your Neon project dashboard → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── JWT Secret ────────────────────────────────────────────────
# Generate a strong random string (run: openssl rand -base64 48)
JWT_SECRET=your_long_random_secret_here_at_least_32_chars

# ─── Stripe ───────────────────────────────────────────────────
# From Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# From Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from Stripe Products
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_ANNUAL=price_...
# App URL for Stripe portal return URL
APP_URL=https://mind-vault-lake.vercel.app
