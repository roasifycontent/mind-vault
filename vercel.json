{
  "version": 2,
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.recallbetter.com" }],
      "destination": "https://recallbetter.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/lp", "destination": "/lp.html" },
    { "source": "/quiz", "destination": "/quiz.html" },
    { "source": "/quiz2", "destination": "/quiz2.html" },
    { "source": "/quiz3", "destination": "/quiz3.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/testimonials", "destination": "/testimonials.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/reset", "destination": "/reset.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
